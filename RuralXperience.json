            "body": { "mode": "raw", "raw": "{\n  \"experienceId\": 1,\n  \"startDate\": \"2026-05-20\",\n  \"endDate\": \"2026-05-21\",\n  \"numberOfGuests\": 2,\n  \"specialRequests\": \"Vegan meals please\"\n}" },
            "url": { "raw": "{{API_BASE_URL}}/api/v1/bookings", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "bookings"] }
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/bookings/my", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "bookings", "my"] }
          }
        },
        {
          "name": "Get Host Bookings",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/bookings/host", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "bookings", "host"] }
          }
        },
        {
          "name": "Confirm Booking",
          "request": {
            "method": "POST",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/bookings/1/confirm", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "bookings", "1", "confirm"] }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/bookings/1/cancel", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "bookings", "1", "cancel"] }
          }
        }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "Get Wishlist",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/wishlist", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "wishlist"] }
          }
        },
        {
          "name": "Add to Wishlist",
          "request": {
            "method": "POST",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/wishlist/1", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "wishlist", "1"] }
          }
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/wishlist/1", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "wishlist", "1"] }
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"bookingId\": 1,\n  \"rating\": 5,\n  \"comment\": \"Amazing experience!\"\n}" },
            "url": { "raw": "{{API_BASE_URL}}/api/v1/reviews", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "reviews"] }
          }
        },
        {
          "name": "Host Reply",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reply\": \"Thank you for coming!\"\n}" },
            "url": { "raw": "{{API_BASE_URL}}/api/v1/reviews/1/reply", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "reviews", "1", "reply"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/admin/users", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "admin", "users"] }
          }
        },
        {
          "name": "Get Pending Experiences",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/admin/experiences/pending", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "admin", "experiences", "pending"] }
          }
        },
        {
          "name": "Approve Experience",
          "request": {
            "method": "POST",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/admin/experiences/1/approve", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "admin", "experiences", "1", "approve"] }
          }
        },
        {
          "name": "Admin Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/admin/stats", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "admin", "stats"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/categories", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "categories"] }
          }
        }
      ]
    }
  ]
}