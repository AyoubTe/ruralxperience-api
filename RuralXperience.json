{
  "info": {
    "name": "RuralXperience API",
    "description": "Generated API Collection with automated JWT injection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "API_BASE_URL", "value": "http://13.56.227.126:8080", "type": "string" },
    { "key": "JWT_TOKEN", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{JWT_TOKEN}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.accessToken) {",
                  "    pm.environment.set(\"JWT_TOKEN\", jsonData.accessToken);",
                  "    console.log(\"Token automatically set in environment!\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{API_BASE_URL}}/api/v1/auth/login", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"new@example.com\",\n  \"password\": \"securePass!\",\n  \"firstName\": \"Alice\",\n  \"lastName\": \"Smith\",\n  \"role\": \"EXPLORER\"\n}" },
            "url": { "raw": "{{API_BASE_URL}}/api/v1/auth/register", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "auth", "register"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"string\"\n}" },
            "url": { "raw": "{{API_BASE_URL}}/api/v1/auth/refresh", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "auth", "refresh"] }
          }
        }
      ]
    },
    {
      "name": "Experiences",
      "item": [
        {
          "name": "Get All Experiences",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/experiences?page=0&size=12", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "experiences"], "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "12" }] }
          }
        },
        {
          "name": "Get Experience by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/experiences/1", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "experiences", "1"] }
          }
        },
        {
          "name": "Create Experience",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "multipart/form-data" }],
            "body": { "mode": "formdata", "formdata": [{ "key": "request", "value": "{\"title\":\"Farm Tour\",\"shortDescription\":\"A cool tour\",\"pricePerPerson\":50,\"durationDays\":1,\"maxGuests\":4}", "type": "text" }, { "key": "files", "type": "file", "src": [] }] },
            "url": { "raw": "{{API_BASE_URL}}/api/v1/experiences", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "experiences"] }
          }
        },
        {
          "name": "Update Experience",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Title\",\n  \"shortDescription\": \"Updated description that meets length requirements\",\n  \"pricePerPerson\": 60,\n  \"durationDays\": 2,\n  \"maxGuests\": 5\n}" },
            "url": { "raw": "{{API_BASE_URL}}/api/v1/experiences/1", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "experiences", "1"] }
          }
        },
        {
          "name": "Submit Experience for Review",
          "request": {
            "method": "POST",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/experiences/1/submit", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "experiences", "1", "submit"] }
          }
        },
        {
          "name": "Host Experiences",
          "request": {
            "method": "GET",
            "url": { "raw": "{{API_BASE_URL}}/api/v1/experiences/host-experiences", "host": ["{{API_BASE_URL}}"], "path": ["api", "v1", "experiences", "host-experiences"] }
          }
        }
      ]
    },
    {
      "name": "Bookings",
